<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlobalLogix | Professional Supply Chain Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .glass-morphism { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
    </style>
</head>
<body class="bg-slate-50">

    <!-- 1. HERO SECTION -->
    <header class="relative h-screen flex items-center justify-center overflow-hidden text-white">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80" 
                 class="w-full h-full object-cover opacity-40" alt="Logistics Background">
            <div class="absolute inset-0 gradient-bg opacity-80"></div>
        </div>
        
        <div class="relative z-10 text-center px-4 max-w-5xl">
            <span class="uppercase tracking-widest text-amber-400 font-bold text-sm mb-4 block">Next-Gen Supply Chain</span>
            <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
                Moving the World, <br><span class="text-amber-500">One Shipment</span> at a Time.
            </h1>
            <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
                Global freight forwarding, real-time tracking, and AI-driven logistics solutions for modern enterprises.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="#book-shipment" class="bg-amber-500 hover:bg-amber-600 text-slate-900 px-8 py-4 rounded-full font-bold transition duration-300 transform hover:scale-105">
                    Book a Shipment Now
                </a>
                <a href="#services" class="border border-white hover:bg-white hover:text-slate-900 px-8 py-4 rounded-full font-bold transition duration-300">
                    Our Services
                </a>
            </div>
        </div>
    </header>

    <!-- 2. TRUST STATS BAR -->
    <section class="relative z-20 -mt-12 max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-white p-8 rounded-2xl shadow-2xl">
            <div class="text-center border-r border-slate-100">
                <h3 class="text-3xl font-bold text-slate-800">150+</h3>
                <p class="text-slate-500 text-sm">Countries Covered</p>
            </div>
            <div class="text-center md:border-r border-slate-100">
                <h3 class="text-3xl font-bold text-slate-800">1.2M</h3>
                <p class="text-slate-500 text-sm">Delivered Yearly</p>
            </div>
            <div class="text-center border-r border-slate-100">
                <h3 class="text-3xl font-bold text-slate-800">99.9%</h3>
                <p class="text-slate-500 text-sm">Success Rate</p>
            </div>
            <div class="text-center">
                <h3 class="text-3xl font-bold text-slate-800">24/7</h3>
                <p class="text-slate-500 text-sm">Global Support</p>
            </div>
        </div>
    </section>

    <!-- 3. SERVICES SECTION -->
    <section id="services" class="py-24 px-4 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold text-slate-900 mb-4">Core Logistics Services</h2>
            <div class="w-24 h-1 bg-amber-500 mx-auto"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Air Freight -->
            <div class="bg-white p-8 rounded-xl border border-slate-100 hover:shadow-xl transition group">
                <div class="w-14 h-14 bg-slate-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-amber-500 transition">
                    <i class="fas fa-plane text-2xl text-slate-800 group-hover:text-white"></i>
                </div>
                <h3 class="text-xl font-bold mb-3">Air Freight</h3>
                <p class="text-slate-600 mb-4">Urgent shipments delivered globally within 48-72 hours with full customs clearance.</p>
                <a href="#" class="text-amber-600 font-semibold hover:underline">Learn more →</a>
            </div>

            <!-- Ocean Freight -->
            <div class="bg-white p-8 rounded-xl border border-slate-100 hover:shadow-xl transition group">
                <div class="w-14 h-14 bg-slate-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-amber-500 transition">
                    <i class="fas fa-ship text-2xl text-slate-800 group-hover:text-white"></i>
                </div>
                <h3 class="text-xl font-bold mb-3">Ocean Freight</h3>
                <p class="text-slate-600 mb-4">Cost-effective FCL and LCL shipping for large-scale international inventory movement.</p>
                <a href="#" class="text-amber-600 font-semibold hover:underline">Learn more →</a>
            </div>

            <!-- Warehousing -->
            <div class="bg-white p-8 rounded-xl border border-slate-100 hover:shadow-xl transition group">
                <div class="w-14 h-14 bg-slate-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-amber-500 transition">
                    <i class="fas fa-warehouse text-2xl text-slate-800 group-hover:text-white"></i>
                </div>
                <h3 class="text-xl font-bold mb-3">Smart Warehousing</h3>
                <p class="text-slate-600 mb-4">Climate-controlled storage with real-time inventory tracking and fulfillment.</p>
                <a href="#" class="text-amber-600 font-semibold hover:underline">Learn more →</a>
            </div>
        </div>
    </section>

    <!-- 4. SHIPMENT BOOKING SECTION (THE FUNCTIONAL PART) -->
    <section id="book-shipment" class="py-24 bg-slate-900 text-white">
        <div class="max-w-4xl mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold mb-4">Instant Shipment Booking</h2>
                <p class="text-slate-400">Complete the form below to get an instant quote and tracking number.</p>
            </div>

            <div class="bg-white text-slate-900 p-8 md:p-12 rounded-3xl shadow-2xl">
                <form id="shipmentForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 text-slate-500">Pickup Location</label>
                            <input type="text" id="origin" required placeholder="City, Country" class="w-full p-4 bg-slate-50 border rounded-xl focus:ring-2 focus:ring-amber-500 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 text-slate-500">Delivery Location</label>
                            <input type="text" id="destination" required placeholder="City, Country" class="w-full p-4 bg-slate-50 border rounded-xl focus:ring-2 focus:ring-amber-500 outline-none transition">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 text-slate-500">Weight (KG)</label>
                            <input type="number" id="weight" required class="w-full p-4 bg-slate-50 border rounded-xl outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 text-slate-500">Priority Level</label>
                            <select id="service" class="w-full p-4 bg-slate-50 border rounded-xl outline-none">
                                <option value="standard">Standard Shipping</option>
                                <option value="express">Express (Air)</option>
                                <option value="priority">Priority Overnight</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 text-slate-500">Package Type</label>
                            <select id="package" class="w-full p-4 bg-slate-50 border rounded-xl outline-none">
                                <option>Box</option>
                                <option>Pallet</option>
                                <option>Fragile Goods</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full bg-amber-500 hover:bg-amber-600 text-slate-900 font-extrabold py-5 rounded-xl transition duration-300 flex justify-center items-center gap-3">
                        <span id="btnText">CREATE SHIPMENT & GENERATE QUOTE</span>
                        <div id="loader" class="hidden w-6 h-6 border-4 border-slate-900 border-t-transparent rounded-full animate-spin"></div>
                    </button>
                </form>

                <!-- Result Message (Hidden) -->
                <div id="successMessage" class="hidden mt-8 p-8 bg-slate-900 rounded-2xl text-white animate-pulse">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <p class="text-amber-500 font-bold uppercase text-xs tracking-widest">Shipment Confirmed</p>
                            <h3 id="trackNum" class="text-2xl font-mono mt-1"></h3>
                        </div>
                        <i class="fas fa-qrcode text-4xl text-white"></i>
                    </div>
                    <div class="border-t border-slate-700 pt-4 flex justify-between">
                        <span class="text-slate-400">Total Freight Cost:</span>
                        <span id="finalCost" class="text-xl font-bold text-amber-500"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. HOW IT WORKS SECTION -->
    <section class="py-24 px-4 bg-white">
        <div class="max-w-6xl mx-auto">
            <div class="flex flex-col md:flex-row items-center gap-16">
                <div class="md:w-1/2">
                    <img src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" class="rounded-3xl shadow-2xl" alt="Worker">
                </div>
                <div class="md:w-1/2">
                    <h2 class="text-4xl font-bold mb-8 text-slate-900">Seamlessly Tracked <br>From Point A to B</h2>
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-amber-100 text-amber-600 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
                            <div>
                                <h4 class="font-bold text-lg">Instant Quote</h4>
                                <p class="text-slate-500">Enter your details and get a binding quote in seconds.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-amber-100 text-amber-600 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
                            <div>
                                <h4 class="font-bold text-lg">Express Pickup</h4>
                                <p class="text-slate-500">Our local fleet arrives within 2 hours of booking confirmation.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-amber-100 text-amber-600 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
                            <div>
                                <h4 class="font-bold text-lg">Live GPS Tracking</h4>
                                <p class="text-slate-500">Monitor your cargo's temperature, location, and speed 24/7.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-slate-950 text-slate-400 py-12 border-t border-slate-900 text-center">
        <p>© 2024 GlobalLogix Systems. All Rights Reserved.</p>
    </footer>

    <script>
        // LOGIC FOR THE SHIPMENT BUTTON
        document.getElementById('shipmentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btnText = document.getElementById('btnText');
            const loader = document.getElementById('loader');
            const submitBtn = document.getElementById('submitBtn');
            const successBox = document.getElementById('successMessage');

            // Show Loading
            btnText.style.display = 'none';
            loader.classList.remove('hidden');
            submitBtn.disabled = true;

            setTimeout(() => {
                // Calculation Logic
                const weight = document.getElementById('weight').value;
                const service = document.getElementById('service').value;
                let price = weight * 12.5;
                if(service === 'express') price *= 1.8;
                if(service === 'priority') price *= 3.2;

                const trackingID = "GLX-" + Math.random().toString(36).substr(2, 9).toUpperCase();

                // Show Result
                document.getElementById('trackNum').innerText = trackingID;
                document.getElementById('finalCost').innerText = "$" + price.toLocaleString(undefined, {minimumFractionDigits: 2});
                
                successBox.classList.remove('hidden');
                
                // Reset Button
                btnText.style.display = 'block';
                loader.classList.add('hidden');
                submitBtn.disabled = false;
                
                // Smooth scroll to result
                successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 2000);
        });
    </script>
</body>
</html>
